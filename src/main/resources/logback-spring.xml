<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 콘솔 로그 패턴 설정 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 로그가 출력되는 포맷을 아주 예쁘게(색상 포함) 지정합니다 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %magenta([%thread]) %cyan(%logger{36}) - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- 파일 로그 패턴 설정 -->
    <!-- 로그를 파일로 저장하고 싶다면 주석을 해제하세요. (운영 환경 적용 시 다룰 예정) -->
    <!--
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        </appender>
        -->

    <!-- 애플리케이션 로그 레벨 설정 -->
    <!-- 우리 프로젝트 패키지 하위의 로그는 DEBUG 레벨까지 촘촘하게 보여주겠다는 뜻! -->
    <logger name="com.example.instagramclone" level="DEBUG"/>

    <!-- 전체 애플리케이션의 기본 로그 레벨 -->
    <!-- 외부 라이브러리(스프링, 하이버네이트 등) 로그는 INFO 레벨부터만 보여줍니다. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <!-- <appender-ref ref="FILE" /> -->
    </root>

</configuration>